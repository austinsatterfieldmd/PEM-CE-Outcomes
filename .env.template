# Automated CE Outcomes Dashboard - Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API Key (required)
# Get your key at: https://openrouter.ai/keys
# Used for: LLM tagging (GPT, Claude, Gemini) + Embeddings (text-embedding-3-small)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Override default models
# OPENROUTER_MODEL_GPT=openai/gpt-5.2
# OPENROUTER_MODEL_CLAUDE=anthropic/claude-opus-4.5
# OPENROUTER_MODEL_GEMINI=google/gemini-2.5-pro
# OPENROUTER_MODEL_SEARCH=perplexity/sonar

# Database (SQLite - local development)
DATABASE_PATH=data/databases/questions.db

# Supabase (Production database - used by import pipeline with --target supabase)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key-here

# Server
API_HOST=127.0.0.1
API_PORT=8000

# Logging
LOG_LEVEL=INFO
