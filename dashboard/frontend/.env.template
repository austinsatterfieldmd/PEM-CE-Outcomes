# Okta Authentication Configuration
# Copy this file to .env.local and fill in your values

# Okta Issuer URL (e.g., https://your-org.okta.com/oauth2/default)
VITE_OKTA_ISSUER=https://your-org.okta.com/oauth2/default

# Okta Client ID (from your Okta SPA application)
VITE_OKTA_CLIENT_ID=your-client-id

# Development mode settings
# Set to "true" to bypass Okta authentication during local development
VITE_DISABLE_AUTH=false
