# =============================================================================
# CME Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.template .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required for SSO)
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
#
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# SSO Configuration (Required for Okta SSO)
# -----------------------------------------------------------------------------
# Get this from Supabase CLI after registering your SSO provider:
#   supabase sso list --project-ref your-project-ref
#
# It's a UUID like: 12345678-1234-1234-1234-123456789012
#
VITE_SSO_PROVIDER_ID=your-sso-provider-id-here

# -----------------------------------------------------------------------------
# Optional: Auth Callback URL Override
# -----------------------------------------------------------------------------
# Only needed for Vercel preview deployments where the URL changes.
# Leave commented out for production and local development.
#
# VITE_AUTH_CALLBACK_URL=https://your-preview-deployment.vercel.app

# -----------------------------------------------------------------------------
# Development Mode Settings
# -----------------------------------------------------------------------------
# Set to "true" to bypass authentication during local development
VITE_DISABLE_AUTH=false

# -----------------------------------------------------------------------------
# Supabase Database Mode (Migration Feature Flag)
# -----------------------------------------------------------------------------
# Set to "true" to use Supabase PostgreSQL directly instead of FastAPI backend.
# When enabled, all data flows: Browser → Supabase JS client → PostgreSQL
# When disabled (default), data flows: Browser → FastAPI → SQLite
#
VITE_USE_SUPABASE=false

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API URL (only needed if using Railway or other external backend)
# Leave commented out to use the default /api path
#
# VITE_API_URL=https://your-backend.up.railway.app/api
