# Automated CE Outcomes Dashboard - Git Ignore

# ===========================================
# ENVIRONMENT & SECRETS
# ===========================================
.env
.env.local
.env.*.local
*.env

# ===========================================
# PYTHON
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# ===========================================
# IDE & EDITORS
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~

# ===========================================
# TESTING
# ===========================================
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# ===========================================
# LOGS
# ===========================================
logs/*.log
*.log

# ===========================================
# DATA FILES (SENSITIVE - DO NOT COMMIT)
# ===========================================

# Database files
*.db
data/databases/*.db
!data/databases/.gitkeep

# Excel files (may contain PII/sensitive data)
*.xlsx
*.xls

# CSV data files
data/**/*.csv

# JSON data files (checkpoints, results, etc.)
data/**/*.json
data/**/*.jsonl

# Text reports
data/**/*.txt

# Keep directory structure
!data/databases/.gitkeep
!data/raw/.gitkeep
!data/review/.gitkeep

# Root-level data files
data/questions.db
data/*.txt
data/*.json

# Checkpoint data
data/checkpoints/
data/corrections/
data/eval/
data/output/

# Dashboard data
dashboard/data/

# Deduplication data
deduplication_v2/data/*.parquet
deduplication_v2/data/*.json
deduplication_v2/data/*.xlsx
deduplication_v2/data/*.csv
deduplication_v2/data/*.txt
deduplication_v2/data/*.yaml
# Keep the summary markdown
!deduplication_v2/data/data_quality_summary.md

# Outcomes data
Outcomes/

# ===========================================
# TEMPORARY & GENERATED FILES
# ===========================================
*.tmp
*.temp
*.bak
nul
_ul
_ul-*

# Test JSON files (root level)
q*.json
response.json
temp_*.json

# ===========================================
# DOCUMENTATION DRAFTS
# ===========================================
*.docx
*.pptx

# ===========================================
# NODE.JS (Dashboard Frontend)
# ===========================================
node_modules/
dashboard/node_modules/
dashboard/frontend/node_modules/
.npm
.pnpm-store/
package-lock.json
dashboard/frontend/package-lock.json

# Build outputs
dashboard/dist/
dashboard/build/
dashboard/frontend/dist/
dashboard/frontend/build/
.vite/

# ===========================================
# OS FILES
# ===========================================
.DS_Store
Thumbs.db
desktop.ini

# ===========================================
# CLAUDE CODE
# ===========================================
.claude/

# ===========================================
# MISC
# ===========================================
# Internal planning documents (not for repo)
Retagging*.md
